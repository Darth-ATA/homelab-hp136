# Garage S3 Credentials
# Copy this file to .env and fill in your values.
# DO NOT commit .env to Git — it's gitignored.

# Garage RPC secret for cluster node authentication (generate with: openssl rand -hex 32)
# Resolved at runtime via fill_secrets() in garage.toml
GARAGE_RPC_SECRET=

# Garage admin token (generate with: openssl rand -hex 32)
GARAGE_ADMIN_TOKEN=

# Garage metrics token (generate with: openssl rand -hex 32)
GARAGE_METRICS_TOKEN=

# Terraform S3 backend credentials
# Also used by Garage v2.3.0 --default-bucket / --default-access-key flags
# Generated by: scripts/setup-garage-state.sh
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
