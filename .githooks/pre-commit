#!/bin/bash
# Pre-commit hook to detect credentials in staged files
# Blocks commits if potential credentials are detected

set -e

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Pattern definitions - each entry: "pattern|description"
CREDENTIAL_PATTERNS=(
  # AWS Keys
  "AKIA[0-9A-Z]{16}|AWS Access Key ID"
  "[aA][wW][sS]_[sS][eE][cC][rR][eE][tT]_[aA][cC][cC][eE][sS][sS]_[kK][eE][yY]|AWS Secret Access Key"
  "aws_secret_access_key|AWS Secret Access Key"

  # Generic API Keys / Secrets
  "api[_-]?key|API Key"
  "apikey|API Key"
  "api[_-]?secret|API Secret"
  "secret[_-]?key|Secret Key"
  "secretkey|Secret Key"
  "private[_-]?key|Private Key"

  # Tokens
  "bearer[_-]?token|Bearer Token"
  "access[_-]?token|Access Token"
  "refresh[_-]?token|Refresh Token"
  "auth[_-]?token|Auth Token"

  # Passwords in various contexts
  "password\s*=|Password assignment"
  "passwd\s*=|Password assignment"
  "pwd\s*=|Password assignment"
  "pass[_-]?word|Password"

  # Database connection strings with credentials
  "postgres(ql)?://[^:]+:[^@]+@|PostgreSQL connection string with credentials"
  "mysql://[^:]+:[^@]+@|MySQL connection string with credentials"
  "mongodb(\+srv)?://[^:]+:[^@]+@|MongoDB connection string with credentials"
  "redis://[^:]+:[^@]+@|Redis connection string with credentials"

  # Private key formats
  "-----BEGIN (RSA |DSA |EC |OPENSSH |PGP )?PRIVATE KEY-----|Private Key"
  "-----BEGIN PGP PRIVATE KEY BLOCK-----|PGP Private Key"

  # Generic secret patterns
  "client[_-]?secret|Client Secret"
  "service[_-]?account[_-]?key|Service Account Key"
  "[aA][pP][iI][tT][oO][kK][eE][nN]|API Token"

  # GitHub/GitLab tokens
  "gh[pousr]_[a-zA-Z0-9]{36}|GitHub Personal Access Token"
  "gla_[a-zA-Z0-9]{20,}|GitLab Personal Access Token"

  # Kubernetes secrets
  "kubernetes.io/token|Kubernetes Service Account Token"
)

# Files to skip (binary files, etc.)
SKIP_PATTERNS="(\.png|\.jpg|\.jpeg|\.gif|\.ico|\.pdf|\.zip|\.tar|\.gz|\.lock|\.tfstate)"

echo "Checking staged files for credentials..."

# Get list of staged files (excluding deleted files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | grep -vE "$SKIP_PATTERNS")

if [ -z "$STAGED_FILES" ]; then
  echo "No staged files to check."
  exit 0
fi

# Create a temporary file for staging matched patterns
TEMP_FILE=$(mktemp)
trap "rm -f $TEMP_FILE" EXIT

# Check each staged file
FOUND_ISSUES=0

while IFS= read -r file; do
  if [ -f "$file" ]; then
    for pattern_info in "${CREDENTIAL_PATTERNS[@]}"; do
      # Split pattern and description
      pattern="${pattern_info%%|*}"
      description="${pattern_info##*|}"

      # Use git show to get the staged version of the file
      # Case-insensitive search with grep
      if git show ":$file" 2>/dev/null | grep -iE "$pattern" > /dev/null 2>&1; then
        # Extract the actual line for context
        LINE=$(git show ":$file" 2>/dev/null | grep -iE "$pattern" | head -n 1)
        echo "$file: $description" >> "$TEMP_FILE"
        echo "  Line: ${LINE:0:100}..." >> "$TEMP_FILE"
        FOUND_ISSUES=$((FOUND_ISSUES + 1))
      fi
    done
  fi
done <<< "$STAGED_FILES"

# Report results
if [ $FOUND_ISSUES -gt 0 ]; then
  echo ""
  echo -e "${RED}============================================${NC}"
  echo -e "${RED}  CREDENTIALS DETECTED IN STAGED FILES${NC}"
  echo -e "${RED}============================================${NC}"
  echo ""
  echo -e "${YELLOW}The following potential credentials were detected:${NC}"
  echo ""

  # Show unique files with issues
  sort -u "$TEMP_FILE"

  echo ""
  echo "--------------------------------------------"
  echo "How to proceed:"
  echo ""
  echo "1. If these are false positives (test data, example configs, etc.):"
  echo "   - Review the detected patterns and add exceptions if needed"
  echo "   - Or use: git commit --no-verify -m 'your message'"
  echo ""
  echo "2. If these are actual credentials:"
  echo "   - Remove the credentials from the files"
  echo "   - Use a secrets manager or environment variables instead"
  echo "   - Add sensitive files to .gitignore"
  echo ""
  echo "3. To temporarily bypass this hook:"
  echo "   git commit --no-verify -m 'your commit message'"
  echo ""
  echo -e "${RED}COMMIT BLOCKED${NC}"
  echo ""

  exit 1
fi

echo "No credentials detected. Proceeding with commit."
exit 0